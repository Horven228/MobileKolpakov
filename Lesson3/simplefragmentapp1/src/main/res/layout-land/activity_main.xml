<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Первый фрагмент занимает 1 часть экрана -->
    <fragment
        android:id="@+id/list"
        android:name="ru.mirea.kolpakovap.simplefragmentapp1.FirstFragment"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <!-- Второй фрагмент занимает 2 части экрана -->
    <fragment
        android:id="@+id/viewer"
        android:name="ru.mirea.kolpakovap.simplefragmentapp1.SecondFragment"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2" />

</LinearLayout>